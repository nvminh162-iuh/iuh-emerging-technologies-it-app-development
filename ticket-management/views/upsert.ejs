<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= ticket ? 'Edit ticket' : 'Add ticket' %></title>
</head>
<body>
    <h1><%= ticket ? 'Sửa vé' : 'Thêm vé' %></h1>

    <form action="<%= ticket ? '/upsert/' + ticket.ticketId : '/upsert' %>" method="post">
        <% if (!ticket) { %>
            <p>
                <label>ticketId</label><br>
                <input name="ticketId" required>
            </p>
        <% } %>

        <p><label>eventName</label><br><input name="eventName" value="<%= ticket?.eventName || '' %>"></p>
        <p><label>holderName</label><br><input name="holderName" value="<%= ticket?.holderName || '' %>"></p>
        <p><label>category</label><br><input name="category" value="<%= ticket?.category || '' %>"></p>
        <p><label>quantity</label><br><input name="quantity" value="<%= ticket?.quantity || '' %>"></p>
        <p><label>pricePerTicket</label><br><input name="pricePerTicket" value="<%= ticket?.pricePerTicket || '' %>"></p>
        <p><label>eventDate</label><br><input name="eventDate" value="<%= ticket?.eventDate || '' %>"></p>
        <p><label>status</label><br><input name="status" value="<%= ticket?.status || '' %>"></p>
        <p><label>imageUrl</label><br><input name="imageUrl" value="<%= ticket?.imageUrl || '' %>"></p>
        <p><label>createdAt</label><br><input name="createdAt" value="<%= ticket?.createdAt || '' %>"></p>

        <button type="submit"><%= ticket ? 'Cập nhật' : 'Thêm mới' %></button>
        <a href="/">Quay lại</a>
    </form>
</body>
</html>
