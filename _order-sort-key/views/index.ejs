<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý đơn hàng</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; color: #1a1a2e; }

    header {
      background: linear-gradient(135deg, #1a1a2e, #16213e);
      color: white; padding: 18px 32px;
      display: flex; align-items: center; justify-content: space-between;
    }
    header h1 { font-size: 1.4rem; font-weight: 700; }

    .btn {
      display: inline-block; padding: 8px 18px; border-radius: 8px;
      font-size: 0.875rem; font-weight: 600; text-decoration: none;
      cursor: pointer; border: none; transition: 0.2s;
    }
    .btn-primary { background: #4f46e5; color: white; }
    .btn-primary:hover { background: #4338ca; }
    .btn-danger  { background: #ef4444; color: white; }
    .btn-danger:hover  { background: #dc2626; }
    .btn-secondary { background: #6b7280; color: white; }
    .btn-secondary:hover { background: #4b5563; }
    .btn-info    { background: #0ea5e9; color: white; }
    .btn-info:hover    { background: #0284c7; }

    /* Filter */
    .filter-section {
      background: white; margin: 20px 32px; padding: 20px 24px;
      border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }
    .filter-section h2 { font-size: 0.9rem; color: #6b7280; margin-bottom: 12px; font-weight: 600; }
    .filter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 10px; align-items: end;
    }
    .filter-grid label { display: block; font-size: 0.78rem; color: #6b7280; margin-bottom: 4px; }
    .filter-grid input, .filter-grid select {
      width: 100%; padding: 8px 10px; border: 1px solid #d1d5db;
      border-radius: 8px; font-size: 0.875rem; background: #f9fafb;
    }
    .filter-grid input:focus, .filter-grid select:focus {
      outline: none; border-color: #4f46e5; background: white;
    }
    .filter-actions { display: flex; gap: 8px; }

    .stats { margin: 0 32px 16px; font-size: 0.85rem; color: #6b7280; }

    /* Card grid – KHÔNG dùng table */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px; margin: 0 32px 40px;
    }
    .card {
      background: white; border-radius: 14px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      overflow: hidden; transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.13); }

    .card-img { width: 100%; height: 180px; object-fit: cover; display: block; }
    .card-img-placeholder {
      width: 100%; height: 180px;
      background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
      display: flex; align-items: center; justify-content: center;
      font-size: 3rem; color: #6366f1;
    }

    .card-body { padding: 16px; }
    .card-title { font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
    .card-sub   { font-size: 0.82rem; color: #6b7280; margin-bottom: 10px; }
    .card-total { font-size: 1.1rem; font-weight: 700; color: #4f46e5; margin-bottom: 10px; }

    .badge {
      display: inline-block; padding: 3px 10px; border-radius: 20px;
      font-size: 0.75rem; font-weight: 600; margin-right: 4px; margin-bottom: 4px;
    }
    .badge-pending  { background: #fef3c7; color: #92400e; }
    .badge-paid     { background: #d1fae5; color: #065f46; }
    .badge-refunded { background: #fee2e2; color: #991b1b; }
    .badge-discount    { background: #ede9fe; color: #5b21b6; }
    .badge-no-discount { background: #f3f4f6; color: #6b7280; }

    .card-badges { margin-bottom: 14px; }
    .card-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .card-actions form { margin: 0; }

    .empty-state {
      grid-column: 1 / -1; text-align: center; padding: 60px 20px; color: #9ca3af;
    }
    .empty-state .icon { font-size: 3rem; margin-bottom: 12px; }
  </style>
</head>
<body>
  <header>
    <h1>📦 Quản lý đơn hàng</h1>
    <a href="/form" class="btn btn-primary">+ Thêm đơn hàng</a>
  </header>

  <!-- Bộ lọc tổng hợp -->
  <div class="filter-section">
    <h2>🔍 Bộ lọc</h2>
    <form action="/" method="GET">
      <div class="filter-grid">
        <div>
          <label>Tên sản phẩm</label>
          <input type="text" name="productName" value="<%= query.productName || '' %>" placeholder="Tìm sản phẩm...">
        </div>
        <div>
          <label>Tên khách hàng</label>
          <input type="text" name="customerName" value="<%= query.customerName || '' %>" placeholder="Tìm khách hàng...">
        </div>
        <div>
          <label>Ngày đặt từ</label>
          <input type="date" name="orderDateFrom" value="<%= query.orderDateFrom || '' %>">
        </div>
        <div>
          <label>Ngày đặt đến</label>
          <input type="date" name="orderDateTo" value="<%= query.orderDateTo || '' %>">
        </div>
        <div>
          <label>Trạng thái thanh toán</label>
          <select name="paymentStatus">
            <option value="ALL" <%= (!query.paymentStatus || query.paymentStatus === 'ALL') ? 'selected' : '' %>>Tất cả</option>
            <option value="Pending"  <%= query.paymentStatus === 'Pending'  ? 'selected' : '' %>>Pending</option>
            <option value="Paid"     <%= query.paymentStatus === 'Paid'     ? 'selected' : '' %>>Paid</option>
            <option value="Refunded" <%= query.paymentStatus === 'Refunded' ? 'selected' : '' %>>Refunded</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="submit" class="btn btn-primary">Lọc</button>
          <a href="/" class="btn btn-secondary">Xóa lọc</a>
        </div>
      </div>
    </form>
  </div>

  <p class="stats">Tìm thấy <strong><%= items.length %></strong> đơn hàng</p>

  <!-- Card layout – KHÔNG dùng table -->
  <div class="card-grid">
    <% if (!items || items.length === 0) { %>
      <div class="empty-state">
        <div class="icon">📭</div>
        <p>Không có đơn hàng nào</p>
      </div>
    <% } else { %>
      <% items.forEach(item => { %>
        <% const { finalTotal } = computeFinalTotal(item.quantity, item.unitPrice, item.taxRate); %>
        <% const dlabel = item.discountLabel || computeDiscountLabel(item.category, item.quantity); %>
        <div class="card">
          <% if (item.imageUrl) { %>
            <img class="card-img" src="<%= item.imageUrl %>" alt="<%= item.productName %>">
          <% } else { %>
            <div class="card-img-placeholder">📷</div>
          <% } %>
          <div class="card-body">
            <div class="card-title"><%= item.productName %></div>
            <div class="card-sub">👤 <%= item.customerName %> &nbsp;|&nbsp; 📅 <%= item.orderDate %></div>
            <div class="card-total"><%= formatCurrency(finalTotal) %></div>
            <div class="card-badges">
              <% if (item.paymentStatus === 'Paid') { %>
                <span class="badge badge-paid">✅ Paid</span>
              <% } else if (item.paymentStatus === 'Pending') { %>
                <span class="badge badge-pending">⏳ Pending</span>
              <% } else { %>
                <span class="badge badge-refunded">↩️ Refunded</span>
              <% } %>
              <% if (dlabel === 'Được ưu đãi') { %>
                <span class="badge badge-discount">🎁 Được ưu đãi</span>
              <% } else { %>
                <span class="badge badge-no-discount">Không ưu đãi</span>
              <% } %>
            </div>
            <div class="card-actions">
              <a href="/detail/<%= item.orderId %>/<%= item.orderDate %>" class="btn btn-info">Chi tiết</a>
              <a href="/form/<%= item.orderId %>/<%= item.orderDate %>"   class="btn btn-secondary">Sửa</a>
              <form action="/items/delete/<%= item.orderId %>/<%= item.orderDate %>" method="POST"
                    onsubmit="return confirm('Xác nhận xóa?')">
                <button type="submit" class="btn btn-danger">Xóa</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</body>
</html>
