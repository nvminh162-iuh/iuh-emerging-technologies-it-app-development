<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="" />
    <meta
      name="author"
      content="Mark Otto, Jacob Thornton, and Bootstrap contributors"
    />
    <meta name="generator" content="Hugo 0.72.0" />
    <title>Album example · Bootstrap</title>

    <link
      rel="canonical"
      href="https://v5.getbootstrap.com/docs/5.0/examples/album/"
    />

    <!-- Bootstrap core CSS -->
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/css/bootstrap.min.css"
      integrity="sha384-r4NyP46KrjDleawBgD5tp8Y7UzmLA05oM1iAEQ17CSuDqnUK2+k9luXQOfXJCJ4I"
      crossorigin="anonymous"
    />
    <script
      src="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/js/bootstrap.min.js"
      integrity="sha384-oesi62hOLfzrys4LxRF63OJCXdXDipiYWBnvTl9Y9/TRlw5xlKIEHpNyvvDShgf/"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"
      integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo"
      crossorigin="anonymous"
    ></script>

    <style>
      .bd-placeholder-img {
        font-size: 1.125rem;
        text-anchor: middle;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
      }

      @media (min-width: 768px) {
        .bd-placeholder-img-lg {
          font-size: 3.5rem;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="navbar navbar-dark bg-dark shadow-sm">
        <div class="container">
          <a href="/" class="navbar-brand d-flex align-items-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              aria-hidden="true"
              class="mr-2"
              viewBox="0 0 24 24"
            >
              <path
                d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"
              />
              <circle cx="12" cy="13" r="4" />
            </svg>
            <strong>Tickets</strong>
          </a>
          <button
            class="navbar-toggler"
            type="button"
            data-toggle="collapse"
            data-target="#navbarHeader"
            aria-controls="navbarHeader"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
        </div>
      </div>
    </header>

    <main>
      <section class="py-5 text-center container">
        <div class="row py-lg-5">
          <div class="col-lg-6 col-md-8 mx-auto">
            <h1 class="font-weight-light">Danh sách vé</h1>
            <p class="lead text-muted">
              Something short and leading about the collection below—its
              contents, the creator, etc. Make it short and sweet, but not too
              short so folks don’t simply skip over it entirely.
            </p>
            <p>
              <a href="/form" class="btn btn-primary my-2">Thêm vé</a>
            </p>
          </div>
        </div>
        <div>
          <form action="/" method="get">
            <input type="text" name="keyword" placeholder="Tìm eventName or holderName">
            <select name="status">
              <option value="ALL">ALL</option>
              <option value="UPCOMING">UPCOMING</option>
              <option value="SOLD">SOLD</option>
              <option value="CANCELLED">CANCELLED</option>
            </select>
            <button type="submit">Tìm kiếm</button>
          </form>
        </div>
      </section>

      <div class="album py-5 bg-light">
        <div class="container">
          <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
            <% if (items.length === 0) { %>
                <h1 class="text-center">Không có Item nào</h1>
            <% } %>
            <% items.forEach(item => { %>
              <% const { amount, finalAmount, discountLabel } = compute(item) %>
              <div class="col">
              <div class="card shadow-sm">
                <img width="100%" height="300px" style="object-fit: contain;" src=<%= item.imageUrl %> alt="">

                <div class="card-body">
                  <p class="card-text"><%= item.id %></p>
                  <p class="card-text"><%= item.eventName %></p>
                  <p class="card-text"><%= item.holderName %></p>
                  <p class="card-text"><%= item.category %></p>
                  <p class="card-text"><%= item.quantity %></p>
                  <p class="card-text"><%= item.pricePerTicket %></p>
                  <p class="card-text"><%= item.eventDate %></p>
                  <p class="card-text"><%= item.status %></p>

                  <p class="card-text">Amount: <%= formatCurrency(amount) %></p>
                  <p class="card-text">FinalAmount: <%=  formatCurrency(finalAmount) %></p>
                  <p class="card-text"><%= discountLabel %></p>

                  <div
                    class="d-flex justify-content-between align-items-center"
                  >
                    <div class="btn-group">
                      <a
                        href="/form/<%= item.id %>"
                        class="btn btn-sm btn-primary"
                      >
                        Edit
                      </a>
                      <form action="/items/delete/<%= item.id %>" method="post">
                        <button
                          type="submit"
                          class="btn btn-sm btn-danger"
                        >
                          Delete
                        </button>
                      </form>
                    </div>
                    <small class="text-muted"><%= item.createdAt %></small>
                  </div>
                </div>
              </div>
            </div>
            <% }) %>
           
          </div>
        </div>
      </div>
    </main>

    <footer class="text-muted py-5">
      <div class="container">
        <p class="float-right mb-1">
          <a href="#">Back to top</a>
        </p>
        <p class="mb-1">
          &copy; Nguyen Van Minh
        </p>
      </div>
    </footer>
  </body>
</html>
